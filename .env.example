# kursiyera — örnek ortam değişkenleri
# Gerçek değerleri kök dizinde .env.local içine yazın; .env.local repoya eklenmemelidir.

# --- Uygulama (Supabase ile ilgisi yok) ---
NEXT_PUBLIC_APP_NAME="kursiyera"
# Opsiyonel: metadataBase / OG için tam site adresi. Vercel’de boş bırakırsanız otomatik VERCEL_URL kullanılır.
# NEXT_PUBLIC_SITE_URL="https://senin-proje.vercel.app"
# Geliştirme bildirimi — WhatsApp (ülke kodu ile, sadece rakam: 905551234567)
NEXT_PUBLIC_WHATSAPP_PHONE=""

# =============================================================================
# Supabase — Dashboard: https://supabase.com/dashboard
# Sol menü: Project Settings (dişli) → menüde "API" veya "Data API"
#
# DOLDURMANIZ GEREKENLER (Supabase’i kodla kullanmak için):
#   1) NEXT_PUBLIC_SUPABASE_URL     → sayfadaki "Project URL"
#   2) NEXT_PUBLIC_SUPABASE_ANON_KEY → "anon" "public" anahtarı (Aşağıdaki alternatif ile birlikte DEĞİL, ikisinden biri.)
#      VEYA NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY → yeni arayüzde "publishable" anahtar
#   3) SUPABASE_SERVICE_ROLE_KEY   → İSTEĞE BAĞLI: yalnız sunucuda RLS’yi aşan admin işlemleri
#                                     için. "service_role" / secret key — ASLA NEXT_PUBLIC_ ile başlatmayın.
#
# Güvenlik:
#   - URL + anon/publishable: tarayıcıda da görünür (normal).
#   - service_role: yalnız .env.local ve Vercel "Environment Variables"; Git / istemci yok.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"

# Aşağıdaki ikisinden yalnızca BİRİNİ doldurun (Dashboard hangi ismi veriyorsa):
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Opsiyonel: service_role secret — Project Settings → API anahtarlar listesinde (sunucu-only).
SUPABASE_SERVICE_ROLE_KEY=""
